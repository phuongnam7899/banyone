# Backend base URL (real devices)
# EXPO_PUBLIC_BACKEND_URL=http://192.168.1.10:3000

# Push (FCM): use a dev build or EAS build with google-services / APNs; Expo Go does not support the full device push flow.

# Firebase client (Expo public — no secrets)
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Optional: Google Sign-In (requires dev client / store-ready OAuth clients)
# EXPO_PUBLIC_AUTH_STRATEGY=google
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Local dev against backend with BANYONE_AUTH_VERIFIER=test — use the contracts test token string
# EXPO_PUBLIC_DEV_FIREBASE_ID_TOKEN=test-valid-token
# EXPO_PUBLIC_DEV_AUTH_UID=test-user-uid
