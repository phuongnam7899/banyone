# Firebase Admin — paste minified JSON for the service account (never commit real secrets)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Alternatively, use Application Default Credentials locally:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Job persistence (optional override)
# BANYONE_JOBS_DATA_DIR=.banyone-jobs-data

# Local / CI test verifier: set to "test" in Jest; uses BANYONE_TEST_FIREBASE_ID_TOKEN from contracts
# BANYONE_AUTH_VERIFIER=test
# BANYONE_AUTH_TEST_UID=test-user-uid

# Per-account request throttling for expensive POST routes (milliseconds window, max requests per window)
# BANYONE_THROTTLE_TTL_MS=60000
# BANYONE_THROTTLE_LIMIT=120

# Credits for video generation
# BANYONE_VIDEO_CREDIT_PER_SECOND=100
# BANYONE_DEFAULT_USER_CREDITS=0

# RevenueCat → POST /v1/billing/revenuecat/webhook (Authorization header must match).
# Without this, webhooks get 401 and credits never increase. Dashboard “transactions” still show.
# Local dev: RevenueCat cannot call localhost; use a tunnel (ngrok, etc.) and set the webhook URL in RC.
# REVENUECAT_WEBHOOK_SECRET=your_webhook_authorization_secret_from_revenuecat

# Local-only: POST /v1/billing/dev/grant-subscription-credits (Firebase auth) to add credits without webhooks.
# Required name on the server (do not use EXPO_PUBLIC_* here — that prefix is only for Expo in apps/mobile/.env).
# Pair mobile: EXPO_PUBLIC_BANYONE_DEV_GRANT_SUBSCRIPTION_CREDITS=true in apps/mobile/.env
# BANYONE_DEV_GRANT_SUBSCRIPTION_CREDITS=true
