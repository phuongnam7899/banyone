# Example environment variables for local development
NODE_ENV=development

# Backend (optional): isolate notification token + dedupe files (defaults to ./.banyone-notifications-data)
# BANYONE_NOTIFICATIONS_DATA_DIR=

# Backend: Firebase Admin — used for auth token verification and FCM sends (same service account as Firebase console)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# or: GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
